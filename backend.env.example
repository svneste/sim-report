# Backend container env. Кладётся на сервере как /opt/melabs-sim/backend.env
# В git НЕ коммитится — содержит секреты amoCRM и пароль к БД.

# postgres-хост — имя сервиса в compose-сети
DATABASE_URL=postgres://amocrm:CHANGE_ME_STRONG_PASSWORD@postgres:5432/amocrm_sim

PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=https://account.mskmegafon.ru

AMOCRM_SUBDOMAIN=melabs
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=https://account.mskmegafon.ru
AMOCRM_AUTH_CODE=

AMOCRM_PIPELINE_ID=4298623
AMOCRM_SIM_FIELD_ID=539427
AMOCRM_SIM_FIELD_TYPE=date

SYNC_CRON=*/15 * * * *
REPORT_EXCLUDED_USER_IDS=1440457
