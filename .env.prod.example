# Compose-уровневый env. Кладётся на сервере как /opt/melabs-sim/.env
# Используется только docker compose-ом для подстановки переменных в compose-файл.
# Не хранит секретов backend-а — те живут в backend.env.

GHCR_OWNER=your-github-username-or-org
IMAGE_TAG=latest

POSTGRES_USER=amocrm
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=amocrm_sim
